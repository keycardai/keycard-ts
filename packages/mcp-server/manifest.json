{
  "dxt_version": "0.2",
  "name": "@keycardai/api-mcp",
  "version": "0.6.0",
  "description": "The official MCP Server for the Keycard API API",
  "author": {
    "name": "Keycard API",
    "email": "support@keycard.ai"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keycardai/keycard-ts.git"
  },
  "homepage": "https://github.com/keycardai/keycard-ts/tree/main/packages/mcp-server#readme",
  "documentation": "https://docs.keycard.ai",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "KEYCARD_API_API_KEY": "${user_config.KEYCARD_API_API_KEY}",
        "KEYCARD_API_CLIENT_ID": "${user_config.KEYCARD_API_CLIENT_ID}",
        "KEYCARD_API_CLIENT_SECRET": "${user_config.KEYCARD_API_CLIENT_SECRET}"
      }
    }
  },
  "user_config": {
    "KEYCARD_API_API_KEY": {
      "title": "api_key",
      "description": "JWT Bearer Token Authentication",
      "required": false,
      "type": "string"
    },
    "KEYCARD_API_CLIENT_ID": {
      "title": "client_id",
      "description": "OAuth2 client ID for service account authentication",
      "required": false,
      "type": "string"
    },
    "KEYCARD_API_CLIENT_SECRET": {
      "title": "client_secret",
      "description": "OAuth2 client secret for service account authentication",
      "required": false,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
